    <style>
        .toast-notification {
            position: fixed;
            right: 24px;
            bottom: 24px;
            z-index: 11000;
            padding: 14px 18px;
            border-radius: 18px;
            background: linear-gradient(135deg, var(--ziggy-purple, #4a2477), var(--ziggy-orange, #ff8c42));
            color: #fff;
            font-weight: 700;
            box-shadow: 0 18px 40px rgba(74, 36, 119, 0.25);
        }
        .auth-error {
            color: #c0392b;
            background: #fdf0ef;
            border: 1px solid #f5c6c2;
            border-radius: 6px;
            padding: 10px 14px;
            margin-top: 10px;
            font-size: 14px;
        }
        .auth-success {
            color: #1a7a4a;
            background: #eafaf1;
            border: 1px solid #a9dfbf;
            border-radius: 6px;
            padding: 10px 14px;
            margin-top: 10px;
            font-size: 14px;
        }
    </style>
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

