@page "/about"
@page "/boarding"
@page "/boarding-checkout"
@page "/boarding-checkout/success"
@page "/boarding-checkout/cancel"
@page "/system"
@page "/products/create"

@inject NavigationManager Navigation

<PageTitle>@Title</PageTitle>

<section class="section-block">
    <div class="section-heading">
        <span>React source route</span>
        <h1>@Title</h1>
    </div>
    <p>This React route has been mapped from the source frontend but is not implemented in Blazor yet.</p>
    <p>Status: Blocked until the matching React page, API contract, state flow, CSS, and assets are ported.</p>
    <a class="btn-secondary" href="/">Back to home</a>
</section>

@code {
    private string Title => new Uri(Navigation.Uri).AbsolutePath.TrimEnd('/').ToLowerInvariant() switch
    {
        "/account" => "Account profile",
        "/profile/edit" => "Edit profile",
        "/account/pets" => "Pet information",
        "/about" => "About",
        "/boarding" => "Boarding rooms",
        "/boarding-checkout" => "Boarding checkout",
        "/boarding-checkout/success" => "Boarding checkout success",
        "/boarding-checkout/cancel" => "Boarding checkout cancelled",
        "/system" => "Staff system",
        "/products/create" => "Create product",
        _ => "Mapped React route"
    };
}
