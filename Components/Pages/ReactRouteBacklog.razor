@page "/react-backlog"
@layout Components.Layout.StaffWorkspaceLayout

<PageTitle>@Title</PageTitle>

<div class="d-flex flex-column justify-content-center align-items-center text-center py-5 mt-5">
    <i class="fas fa-tools text-warning mb-4" style="font-size: 5rem;"></i>
    <h1 class="fw-bold text-dark mb-3">Tính năng đang phát triển</h1>
    <p class="fs-4 text-muted w-50">Trang này hiện đang được nâng cấp hệ thống (Chuyển đổi React sang Blazor C#). Vui lòng quay lại sau.</p>
</div>

@code {
    private string Title { get; set; } = "Hệ thống đang bảo trì";
}