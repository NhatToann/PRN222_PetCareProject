@page "/forgot-password"
@layout PetShop_PRN222.Components.Layout.EmptyLayout
@inject PetShop.Interfaces.IAuthClient AuthClient
@inject NavigationManager Navigation

<PageTitle>Quên mật khẩu – Pet Toy Shop</PageTitle>

<div class="auth-page">

    <!-- Brand logo top-right -->
    <a href="/" class="brand-logo brand-logo--auth logo-home" aria-label="Pet Toy Shop">
        <div class="brand-logo__img">
            <img src="https://images.unsplash.com/photo-1583511655857-d19b40a7a54e?w=160&q=80" alt="" width="56" height="56" decoding="async" />
        </div>
        <span class="brand-logo__text">Pet Toy Shop</span>
    </a>

    <!-- LEFT hero panel -->
    <div class="auth-left">
        <h2>Quên mật khẩu</h2>
        <p>Thực hiện theo từng bước để đặt lại mật khẩu</p>
    </div>

    <!-- RIGHT form panel -->
    <div class="auth-right">
        <h3>ĐẶT LẠI MẬT KHẨU</h3>

        <!-- STEP 1: Enter email to receive OTP -->
        @if (step == 1)
        {
            <form @onsubmit="HandleSendOtpAsync" @onsubmit:preventDefault>
                <input type="email"
                       id="fp-email"
                       placeholder="Email"
                       value="@otpEmail"
                       @oninput="e => otpEmail = e.Value?.ToString() ?? string.Empty"
                       required
                       disabled="@isBusy" />

                <button type="submit" disabled="@isBusy">
                    @(sendOtpLoading ? "Đang gửi OTP..." : "Gửi OTP")
                </button>

                @if (!string.IsNullOrWhiteSpace(otpError))
                {
                    <div class="auth-error">@otpError</div>
                }
                @if (!string.IsNullOrWhiteSpace(actionMessage))
                {
                    <div class="auth-success">@actionMessage</div>
                }
            </form>
        }

        <!-- STEP 2: Enter OTP received by email -->
        @if (step == 2)
        {
            <form @onsubmit="HandleVerifyOtpAsync" @onsubmit:preventDefault>
                <input type="email"
                       id="fp-otp-email"
                       placeholder="Email"
                       value="@otpEmail"
                       @oninput="e => otpEmail = e.Value?.ToString() ?? string.Empty"
                       required
                       disabled="@isBusy" />

                <input type="text"
                       id="fp-otp-code"
                       placeholder="OTP Code"
                       value="@otpCode"
                       @oninput="e => otpCode = e.Value?.ToString() ?? string.Empty"
                       required
                       disabled="@isBusy" />

                <button type="submit" disabled="@isBusy">
                    @(verifyOtpLoading ? "Đang xác minh..." : "Xác minh OTP")
                </button>

                <button type="button"
                        class="google-login-btn"
                        @onclick="HandleResendOtpAsync"
                        disabled="@(isBusy || resendCountdown > 0)">
                    @if (resendLoading)
                    {
                        <span>Đang gửi lại OTP...</span>
                    }
                    else if (resendCountdown > 0)
                    {
                        <span>Gửi lại OTP (@(resendCountdown)s)</span>
                    }
                    else
                    {
                        <span>Gửi lại OTP</span>
                    }
                </button>

                @if (!string.IsNullOrWhiteSpace(otpError))
                {
                    <div class="auth-error">@otpError</div>
                }
                @if (!string.IsNullOrWhiteSpace(actionMessage))
                {
                    <div class="auth-success">@actionMessage</div>
                }
            </form>
        }

        <!-- STEP 3: Set new password -->
        @if (step == 3)
        {
            <form @onsubmit="HandleResetPasswordAsync" @onsubmit:preventDefault>
                <input type="email"
                       id="fp-reset-email"
                       placeholder="Email"
                       value="@resetEmail"
                       @oninput="e => resetEmail = e.Value?.ToString() ?? string.Empty"
                       required
                       disabled="@(isBusy || !string.IsNullOrWhiteSpace(verifiedEmail))" />

                <input type="password"
                       id="fp-new-password"
                       placeholder="Mật khẩu mới"
                       value="@newPassword"
                       @oninput="e => newPassword = e.Value?.ToString() ?? string.Empty"
                       required
                       disabled="@isBusy" />

                <input type="password"
                       id="fp-confirm-password"
                       placeholder="Xác nhận mật khẩu"
                       value="@confirmPassword"
                       @oninput="e => confirmPassword = e.Value?.ToString() ?? string.Empty"
                       required
                       disabled="@isBusy" />

                <button type="submit" disabled="@isBusy">
                    @(resetLoading ? "Đang reset..." : "Reset Password")
                </button>

                @if (!string.IsNullOrWhiteSpace(resetError))
                {
                    <div class="auth-error">@resetError</div>
                }
                @if (!string.IsNullOrWhiteSpace(actionMessage))
                {
                    <div class="auth-success">@actionMessage</div>
                }
            </form>
        }

        <p><a href="/login">Quay lại đăng nhập</a></p>
    </div>
</div>

@code {
    private int step = 1;

    // OTP fields
    private string otpEmail = string.Empty;
    private string otpCode = string.Empty;

    // Reset password fields
    private string resetEmail = string.Empty;
    private string newPassword = string.Empty;
    private string confirmPassword = string.Empty;

    private string verifiedEmail = string.Empty;
    private string resetToken = string.Empty;

    // Loading states
    private bool sendOtpLoading;
    private bool verifyOtpLoading;
    private bool resetLoading;
    private bool resendLoading;
    private int resendCountdown;

    private bool isBusy => sendOtpLoading || verifyOtpLoading || resetLoading || resendLoading;

    private string? otpError;
    private string? resetError;
    private string? actionMessage;

    private System.Threading.Timer? countdownTimer;

    private async Task HandleSendOtpAsync()
    {
        otpError = null;
        actionMessage = null;

        if (string.IsNullOrWhiteSpace(otpEmail))
        {
            otpError = "Vui lòng nhập email để gửi OTP.";
            return;
        }

        sendOtpLoading = true;
        var result = await AuthClient.SendOtpAsync(new PetShop.Models.SendEmailOtpRequestDto(otpEmail.Trim()));
        sendOtpLoading = false;

        if (!result.IsSuccess)
        {
            otpError = result.Error ?? "Gửi OTP thất bại.";
            return;
        }

        resetEmail = otpEmail.Trim();
        resetToken = string.Empty;
        StartResendCountdown(120);
        actionMessage = "Đã gửi OTP đến email.";
        step = 2;
    }

    private async Task HandleResendOtpAsync()
    {
        if (resendCountdown > 0 || resendLoading) return;
        otpError = null;
        actionMessage = null;

        if (string.IsNullOrWhiteSpace(otpEmail))
        {
            otpError = "Vui lòng nhập email để gửi OTP.";
            return;
        }

        resendLoading = true;
        var result = await AuthClient.SendOtpAsync(new PetShop.Models.SendEmailOtpRequestDto(otpEmail.Trim()));
        resendLoading = false;

        if (!result.IsSuccess)
        {
            otpError = result.Error ?? "Gửi OTP thất bại.";
            return;
        }

        StartResendCountdown(120);
        actionMessage = "Đã gửi lại OTP.";
    }

    private async Task HandleVerifyOtpAsync()
    {
        otpError = null;
        actionMessage = null;

        if (string.IsNullOrWhiteSpace(otpEmail) || string.IsNullOrWhiteSpace(otpCode))
        {
            otpError = "Vui lòng nhập email và OTP.";
            return;
        }

        verifyOtpLoading = true;
        var result = await AuthClient.VerifyOtpAsync(new PetShop.Models.VerifyEmailOtpRequestDto(otpEmail.Trim(), otpCode.Trim()));
        verifyOtpLoading = false;

        if (!result.IsSuccess)
        {
            otpError = result.Error ?? "Xác minh OTP thất bại.";
            return;
        }

        verifiedEmail = otpEmail.Trim();
        resetEmail = verifiedEmail;
        resetToken = result.Data?.Message ?? string.Empty;
        StopCountdown();
        resendCountdown = 0;
        actionMessage = "OTP hợp lệ. Bạn có thể đặt mật khẩu mới.";
        step = 3;
    }

    private async Task HandleResetPasswordAsync()
    {
        resetError = null;
        actionMessage = null;

        if (string.IsNullOrWhiteSpace(resetEmail))
        {
            resetError = "Vui lòng nhập email.";
            return;
        }
        if (string.IsNullOrWhiteSpace(newPassword) || string.IsNullOrWhiteSpace(confirmPassword))
        {
            resetError = "Vui lòng nhập mật khẩu mới và xác nhận.";
            return;
        }
        if (string.IsNullOrWhiteSpace(resetToken))
        {
            resetError = "Reset token chưa được tạo. Hãy xác minh OTP trước.";
            return;
        }
        if (!string.IsNullOrWhiteSpace(verifiedEmail) &&
            !string.Equals(resetEmail.Trim(), verifiedEmail, StringComparison.OrdinalIgnoreCase))
        {
            resetError = "Email không khớp với email đã xác thực OTP.";
            return;
        }

        resetLoading = true;
        var result = await AuthClient.ResetPasswordAsync(new PetShop.Models.ResetPasswordRequestDto(
            resetEmail.Trim(), resetToken, null, newPassword, confirmPassword));
        resetLoading = false;

        if (!result.IsSuccess)
        {
            resetError = result.Error ?? "Reset mật khẩu thất bại.";
            return;
        }

        actionMessage = "Mật khẩu đã được cập nhật thành công. Vui lòng đăng nhập lại.";
    }

    private void StartResendCountdown(int seconds)
    {
        resendCountdown = seconds;
        StopCountdown();
        countdownTimer = new System.Threading.Timer(_ =>
        {
            if (resendCountdown > 0)
            {
                resendCountdown--;
                InvokeAsync(StateHasChanged);
            }
            else
            {
                StopCountdown();
            }
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    private void StopCountdown()
    {
        countdownTimer?.Dispose();
        countdownTimer = null;
    }

    public void Dispose() => StopCountdown();
}
