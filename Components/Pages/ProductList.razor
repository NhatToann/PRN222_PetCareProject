@page "/products/list"
@layout PetShop_PRN222.Components.Layout.StaffWorkspaceLayout
@rendermode InteractiveServer
@using PetShop.Data
@using Microsoft.EntityFrameworkCore
@using PetShop.Models
@using Microsoft.Extensions.DependencyInjection
@inject IServiceProvider ServiceProvider
@inject IJSRuntime JSRuntime

<PageTitle>Danh Sách Sản Phẩm</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div><h2 class="fw-bold mb-0 text-dark">Danh Sách Sản Phẩm</h2><p class="text-muted mb-0">Tổng số: <span class="fw-bold text-primary">@allProducts?.Count</span> sản phẩm</p></div>
    <a href="/products/create" class="btn btn-primary rounded-pill px-4 fw-bold shadow"><i class="fas fa-plus me-2"></i> Tạo mới</a>
</div>

<div class="fox-card p-4 mb-4">
    <div class="input-group input-group-lg shadow-sm rounded-pill overflow-hidden border">
        <span class="input-group-text bg-white border-0"><i class="fas fa-search text-muted"></i></span>
        <input type="text" class="form-control border-0 shadow-none" placeholder="Tìm kiếm theo tên sản phẩm..." @bind="searchQuery" @bind:event="oninput" @onkeyup="ApplySearch" />
    </div>
</div>

<div class="fox-card p-0 overflow-hidden shadow-sm border-0">
    @if (displayedProducts == null)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else if (!displayedProducts.Any())
    {
        <div class="text-center py-5">
            <img src="https://cdn-icons-png.flaticon.com/512/7486/7486754.png" width="100" class="opacity-50 mb-3" />
            <h5 class="text-muted fw-bold">Không có sản phẩm nào</h5>
            <a href="/products/create" class="btn btn-outline-primary rounded-pill px-4 mt-2 fw-bold"><i class="fas fa-plus me-1"></i> Thêm sản phẩm đầu tiên</a>
        </div>
    }
    else
    {
        <table class="table fox-table table-hover align-middle mb-0 text-center">
            <thead class="table-light">
                <tr>
                    <th class="text-start ps-4">Sản Phẩm</th>
                    <th>Giá Bán</th>
                    <th>Tồn Kho</th>
                    <th class="pe-4">Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in displayedProducts)
                {
                    <tr style="cursor:pointer;">
                        <td class="text-start ps-4 py-3 d-flex align-items-center gap-3" @onclick="() => ShowDetail(p)">
                            <img src="@(string.IsNullOrEmpty(p.ImageUrl) ? "/img/placeholder.jpg" : p.ImageUrl)" class="rounded-3 shadow-sm border" style="width: 50px; height: 50px; object-fit: cover;" />
                            <div><div class="fw-bold text-dark">@p.Name</div><small class="text-muted fw-bold">SKU: #PRD-@(p.ProductId.ToString("D4"))</small></div>
                        </td>
                        <td class="fw-bold text-success">@p.Price.ToString("N0") đ</td>
                        <td>
                            @if (p.StockQuantity > 50)
                            {
                                <span class="badge bg-success rounded-pill px-3"><i class="fas fa-circle text-white me-1" style="font-size:8px;"></i> @p.StockQuantity</span>
                            }
                            else if (p.StockQuantity > 5)
                            {

                                <span class="badge bg-warning text-dark rounded-pill px-3"><i class="fas fa-circle text-dark me-1" style="font-size:8px;"></i> @p.StockQuantity</span>
                            }
                            else
                            {

                                <span class="badge bg-danger rounded-pill px-3"><i class="fas fa-circle text-white me-1" style="font-size:8px;"></i> @p.StockQuantity</span>
                            }
                        </td>
                        <td class="pe-4">
                            <button class="btn btn-sm btn-light fw-bold me-2 shadow-sm text-primary" @onclick="() => ShowDetail(p)"><i class="fas fa-eye"></i> Xem</button>
                            <a href="/products/edit/@p.ProductId" class="btn btn-sm btn-light fw-bold me-2 shadow-sm text-warning"><i class="fas fa-edit"></i> Sửa</a>
                            <button class="btn btn-sm btn-light fw-bold shadow-sm text-danger" @onclick="() => ConfirmDelete(p.ProductId)"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<!-- Modal Chi tiết Sản phẩm -->
@if (detailProduct != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4 border-0">
                <div class="modal-header border-0 pb-0 justify-content-end"><button class="btn-close" @onclick="() => detailProduct = null"></button></div>
                <div class="modal-body text-center pt-0 px-5 pb-5">
                    <img src="@detailProduct.ImageUrl" class="rounded-4 shadow mb-4" style="width: 200px; height: 200px; object-fit: cover;" />
                    <h4 class="fw-bold text-dark">@detailProduct.Name</h4>
                    <p class="text-muted fw-bold">SKU: #PRD-@(detailProduct.ProductId.ToString("D4"))</p>
                    <div class="d-flex justify-content-center gap-3 my-3">
                        <div class="p-3 bg-light rounded-4 w-50">
                            <div class="text-muted small fw-bold">GIÁ BÁN</div>
                            <h4 class="text-primary fw-bold mb-0">@detailProduct.Price.ToString("N0") đ</h4>
                        </div>
                        <div class="p-3 bg-light rounded-4 w-50">
                            <div class="text-muted small fw-bold">TỒN KHO</div>
                            <h4 class="text-success fw-bold mb-0">@detailProduct.StockQuantity chiếc</h4>
                        </div>
                    </div>
                    <p class="text-start bg-light p-3 rounded-3 text-muted">@detailProduct.Description</p>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Product>? allProducts;
    private List<Product>? displayedProducts;
    private string searchQuery = "";
    private Product? detailProduct;

    protected override async Task OnInitializedAsync() { await LoadProducts(); }

    private async Task LoadProducts()
    {
        using var scope = ServiceProvider.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<ShopPetDatabaseContext>();
        allProducts = await db.Products.AsNoTracking().Where(p => !p.IsDeleted).OrderByDescending(p => p.ProductId).ToListAsync();
        ApplySearch();
    }

    private void ApplySearch()
    {
        if (string.IsNullOrWhiteSpace(searchQuery)) displayedProducts = allProducts;
        else displayedProducts = allProducts?.Where(p => p.Name.ToLower().Contains(searchQuery.ToLower())).ToList();
    }

    private void ShowDetail(Product p) { detailProduct = p; }

    private async Task ConfirmDelete(int id)
    {
        bool isConfirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Bạn có chắc chắn muốn chuyển sản phẩm này vào Thùng rác không?");
        if (isConfirmed)
        {
            using var scope = ServiceProvider.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<ShopPetDatabaseContext>();
            await db.Database.ExecuteSqlRawAsync("UPDATE Products SET is_deleted = 1 WHERE product_id = {0}", id);
            await LoadProducts();
        }
    }
}