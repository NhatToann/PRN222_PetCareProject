@page "/products/deleted"
@layout PetShop_PRN222.Components.Layout.StaffWorkspaceLayout
@rendermode InteractiveServer
@using PetShop.Data
@using Microsoft.EntityFrameworkCore
@using PetShop.Models
@inject ShopPetDatabaseContext _context

<PageTitle>Thùng Rác Sản Phẩm</PageTitle>

<div class="mb-4">
    <h2 class="fw-bold mb-1 text-danger"><i class="fas fa-trash-alt me-2"></i> Thùng Rác Sản Phẩm</h2>
    <p class="text-muted fs-5">Sản phẩm ở đây sẽ không hiển thị trên cửa hàng</p>
</div>

<div class="fox-card p-0 overflow-hidden border-top border-danger border-4">
    @if (products == null)
    {
        <div class="text-center py-5"><div class="spinner-border text-danger"></div></div>
    }
    else if (!products.Any())
    {
        <div class="text-center py-5 my-4">
            <h4 class="text-muted fw-bold">Thùng rác đang trống.</h4>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table fox-table table-hover align-middle mb-0 text-center">
                <thead class="table-light">
                    <tr>
                        <th class="py-3 text-start ps-4">Sản Phẩm</th>
                        <th>Giá Bán</th>
                        <th class="pe-4">Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in products)
                    {
                        <tr>
                            <td class="text-start ps-4 py-3 fw-bold text-dark fs-5">
                                <span class="text-decoration-line-through text-muted">@p.Name</span>
                            </td>
                            <td class="fw-bold fs-5 text-secondary">@p.Price.ToString("N0") đ</td>
                            <td class="pe-4">
                                <button class="btn btn-sm btn-success rounded-pill px-3 fw-bold shadow-sm me-2" @onclick="() => Restore(p.ProductId)">
                                    <i class="fas fa-undo"></i> Khôi phục
                                </button>
                                <button class="btn btn-sm btn-danger rounded-pill px-3 fw-bold shadow-sm" @onclick="() => HardDelete(p.ProductId)">
                                    <i class="fas fa-times"></i> Xóa vĩnh viễn
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<Product>? products;

    protected override async Task OnInitializedAsync() { await Load(); }
    private async Task Load() { products = await _context.Products.Where(p => p.IsDeleted).ToListAsync(); }

    private async Task Restore(int id)
    {
        var product = await _context.Products.FindAsync(id);
        if (product != null) { product.IsDeleted = false; await _context.SaveChangesAsync(); await Load(); }
    }

    private async Task HardDelete(int id)
    {
        var product = await _context.Products.FindAsync(id);
        if (product != null) { _context.Products.Remove(product); await _context.SaveChangesAsync(); await Load(); }
    }
}