    .modal-actions .btn-secondary { background: #ecf0f1; color: #6c7a89; }
    .modal-actions button:disabled { opacity: 0.5; cursor: not-allowed; }
</style>

@implements IDisposable

@code {
    private List<BoardingBookingDto> Bookings { get; set; } = new();
    private bool IsLoading { get; set; } = true;
    private bool IsStaff { get; set; }
    private string DebugInfo { get; set; } = "Initializing...";
    private string ActiveFilter { get; set; } = "all";
    private string SearchTerm { get; set; } = "";
    private readonly HashSet<int> ProcessingIds = new();
    private readonly Dictionary<int, (string Message, bool IsSuccess)> ActionFeedback = new();

    private bool ShowRejectDialog { get; set; }
    private BoardingBookingDto? RejectTarget { get; set; }
    private string RejectReason { get; set; } = "";

    private Timer? _refreshTimer;

    private IEnumerable<BoardingBookingDto> FilteredBookings
    {
        get
        {
            var filtered = ActiveFilter == "all"
                ? Bookings
                : ActiveFilter == "Chưa thanh toán"
                    ? Bookings.Where(b => b.Status == "Chờ xác nhận" && b.PaymentMethod == "cod")
                    : Bookings.Where(b => b.Status == ActiveFilter);

            if (!string.IsNullOrWhiteSpace(SearchTerm))
            {
                var term = SearchTerm.Trim();
                filtered = filtered.Where(b =>
                    (b.Customer?.Name?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (b.Customer?.Phone?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (b.Customer?.Email?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    b.BookingId.ToString().Contains(term));
            }

            return filtered
                .OrderBy(b => b.Status switch
                {
                    "Chờ xác nhận" => 0,
                    "Đã thanh toán" => 1,
                    "Đang sử dụng" => 2,
                    "Đã trả phòng" => 3,
                    _ => 4
                })
                .ThenByDescending(b => b.CreatedAt)
                .ThenBy(b => b.CheckInDate);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try { await UserSession.LoadAsync(); }
        catch (Exception ex)
        {
            Console.WriteLine($"[StaffBoardingSchedule] LoadAsync error: {ex.Message}");
        }

        DebugInfo = $"Session loaded: IsAuth={UserSession.IsAuthenticated}, " +
                    $"User={(UserSession.CurrentUser?.Name ?? "null")}, " +
                    $"Role={UserSession.CurrentUser?.Role ?? "null"}, " +
                    $"Time={DateTime.Now:HH:mm:ss}";

        if (!UserSession.IsAuthenticated)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        IsStaff = UserSession.CurrentUser?.Role?.ToLowerInvariant() == "staff";
        if (!IsStaff)
        {
            DebugInfo += " | CẢNH BÁO: Bạn đang đăng nhập với role '" +
                         (UserSession.CurrentUser?.Role ?? "?") +
                         "', không phải staff. Vẫn xem được nhưng nên đăng nhập bằng tài khoản staff.";
        }

        await LoadBookings();

        // Auto-refresh every 30 seconds so new bookings appear without manual reload
        _refreshTimer = new Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await LoadBookings();
            });
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }

    private async Task LoadBookings()
    {
        IsLoading = true;
        try
        {
            var result = await BoardingClient.GetAllBookingsAsync();
            if (result.IsSuccess && result.Data != null)
            {
                Bookings = result.Data.ToList();

                // For any "Chờ xác nhận" booking, poll PayOS to sync real payment status.
                // This is needed because PayOS webhooks may not be reachable from local/dev
                // environments. Staff should always see the latest payment state.
                var pendingBookings = Bookings.Where(b => b.Status == "Chờ xác nhận").ToList();
                if (pendingBookings.Count > 0)
                {
                    using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(5));
                    var paymentCheckTasks = pendingBookings
                        .Select(b => BoardingClient.GetBookingPaymentStatusAsync(b.BookingId, cts.Token))
                        .ToList();

                    try { await Task.WhenAll(paymentCheckTasks); } catch (OperationCanceledException) { /* PayOS slow — skip */ }

                    foreach (var task in paymentCheckTasks)
                    {
                        if (!task.IsCompletedSuccessfully) continue;
                        var paymentResult = task.Result;
                        if (paymentResult.IsSuccess && paymentResult.Data != null)
                        {
                            var booking = Bookings.FirstOrDefault(b => b.BookingId == paymentResult.Data.BookingId);
                            if (booking != null && paymentResult.Data.BookingStatus == "Đã thanh toán")
                            {
                                var idx = Bookings.IndexOf(booking);
                                Bookings[idx] = booking with { Status = "Đã thanh toán" };
                            }
                        }
                    }
                }
            }
            else
            {
                ActionFeedback.Clear();
                ActionFeedback[-1] = (result.Error ?? "Không tải được danh sách booking.", false);
            }
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void SetFilter(string filter)
    {
        ActiveFilter = filter;
    }

    private int CountByStatus(string status)
        => Bookings.Count(b => b.Status == status);

    private static string GetStatusClass(string status) => status switch
    {
        "Chờ xác nhận" => "status-pending",
        "Đã thanh toán" => "status-confirmed",
        "Đang sử dụng" => "status-active",
        "Đã trả phòng" => "status-done",
        _ => ""
    };

    private static int ExtractPetCount(string? petInfo)
    {
        if (string.IsNullOrWhiteSpace(petInfo)) return 0;
        var m = System.Text.RegularExpressions.Regex.Match(petInfo, @"\d+");
        return m.Success ? int.Parse(m.Value) : 0;
    }

    private static string RelativeDate(DateOnly date)
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        var delta = date.DayNumber - today.DayNumber;
        return delta switch
        {
            0 => "Hôm nay",
            1 => "Ngày mai",
            -1 => "Hôm qua",
            > 0 => $"Còn {delta} ngày",
            _ => $"Đã qua {-delta} ngày"
        };
    }

    private bool IsProcessing(int id) => ProcessingIds.Contains(id);

    private void SetFeedback(int id, string message, bool success)
    {
        ActionFeedback[id] = (message, success);
    }

    private string ActionFeedbackClass(int id)
        => ActionFeedback.TryGetValue(id, out var f) && f.IsSuccess ? "success" : "error";

    private async Task ConfirmBooking(BoardingBookingDto booking)
    {
        // "Chờ xác nhận" → "Đang sử dụng" via ConfirmCheckinAsync on the controller;
        // OR for cleaner staff semantics, treat confirmation as approving the request.
        // Since /checkin transitions to "Đang sử dụng" directly, we use that as confirmation.
        ProcessingIds.Add(booking.BookingId);
        try
        {
            var result = await BoardingClient.ConfirmCheckinAsync(booking.BookingId);
            if (result.IsSuccess)
            {
                SetFeedback(booking.BookingId, "✓ Đã xác nhận booking thành công.", true);
                await LoadBookings();
            }
            else
            {
                SetFeedback(booking.BookingId, $"✗ {result.Error ?? "Lỗi khi xác nhận."}", false);
            }
        }
        finally
        {
            ProcessingIds.Remove(booking.BookingId);
        }
    }

    private void OpenRejectDialog(BoardingBookingDto booking)
    {
        RejectTarget = booking;
        RejectReason = "";
        ShowRejectDialog = true;
    }

    private void CloseRejectDialog()
    {
        ShowRejectDialog = false;
        RejectTarget = null;
        RejectReason = "";
    }

    private async Task SubmitReject()
    {
        if (RejectTarget == null || string.IsNullOrWhiteSpace(RejectReason)) return;
        var id = RejectTarget.BookingId;
        ProcessingIds.Add(id);
        try
        {
            var result = await BoardingClient.RejectBookingAsync(id, RejectReason.Trim());
            if (result.IsSuccess)
            {
                SetFeedback(id, "✓ Đã từ chối booking.", true);
                CloseRejectDialog();
                await LoadBookings();
            }
            else
            {
                SetFeedback(id, $"✗ {result.Error ?? "Lỗi khi từ chối."}", false);
            }
        }
        finally
        {
            ProcessingIds.Remove(id);
        }
    }

    private async Task CheckInGuest(BoardingBookingDto booking)
    {
        ProcessingIds.Add(booking.BookingId);
        try
        {
            var result = await BoardingClient.ConfirmCheckinAsync(booking.BookingId);
            if (result.IsSuccess)
            {
                SetFeedback(booking.BookingId, "✓ Check-in thành công.", true);
                await LoadBookings();
            }
            else
            {
                SetFeedback(booking.BookingId, $"✗ {result.Error ?? "Lỗi khi check-in."}", false);
            }
        }
        finally
        {
            ProcessingIds.Remove(booking.BookingId);
        }
    }

    private async Task CheckOutGuest(BoardingBookingDto booking)
    {
        ProcessingIds.Add(booking.BookingId);
        try
        {
            var result = await BoardingClient.ConfirmCheckoutAsync(booking.BookingId);
            if (result.IsSuccess)
            {
                SetFeedback(booking.BookingId, "✓ Check-out & hoàn tất booking.", true);
                await LoadBookings();
            }
            else
            {
                SetFeedback(booking.BookingId, $"✗ {result.Error ?? "Lỗi khi check-out."}", false);
            }
        }
        finally
        {
            ProcessingIds.Remove(booking.BookingId);
        }
    }
}
