@page "/staff/boarding"
@using PetShop.Models
@inject IBoardingClient BoardingClient
@inject UserSessionService UserSession
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Lịch đặt phòng - Staff</PageTitle>

<div class="staff-boarding">
    <header class="page-header">
        <div class="header-row">
            <div>
                <h1>Lịch đặt phòng lưu trú</h1>
                <p class="subtitle">Quản lý và xác nhận các booking từ khách hàng</p>
            </div>
            <div class="header-actions">
                <button class="btn-refresh" @onclick="LoadBookings">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
                        <path d="M17.65 6.35A7.95 7.95 0 0 0 12 4a8 8 0 1 0 7.73 10h-2.08A6 6 0 1 1 12 6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/>
                    </svg>
                    Làm mới
                </button>
            </div>
        </div>

        <div class="stat-grid">
            <div class="stat-card stat-pending">
                <span class="stat-label">Chờ xác nhận</span>
                <span class="stat-value">@CountByStatus("Chờ xác nhận")</span>
            </div>
            <div class="stat-card stat-confirmed">
                <span class="stat-label">Đã thanh toán</span>
                <span class="stat-value">@CountByStatus("Đã thanh toán")</span>
            </div>
            <div class="stat-card stat-active">
                <span class="stat-label">Đang sử dụng</span>
                <span class="stat-value">@CountByStatus("Đang sử dụng")</span>
            </div>
            <div class="stat-card stat-done">
                <span class="stat-label">Đã trả phòng</span>
                <span class="stat-value">@CountByStatus("Đã trả phòng")</span>
            </div>
        </div>

        <div class="filter-row">
            <div class="filter-tabs">
                <button class="filter-tab @(ActiveFilter == "all" ? "active" : "")" @onclick='() => SetFilter("all")'>
                    Tất cả <span class="tab-count">@Bookings.Count</span>
                </button>
                <button class="filter-tab @(ActiveFilter == "Chờ xác nhận" ? "active" : "")" @onclick='() => SetFilter("Chờ xác nhận")'>
                    Chờ xác nhận <span class="tab-count pending">@CountByStatus("Chờ xác nhận")</span>
                </button>
                <button class="filter-tab @(ActiveFilter == "Đã thanh toán" ? "active" : "")" @onclick='() => SetFilter("Đã thanh toán")'>
                    Đã thanh toán <span class="tab-count confirmed">@CountByStatus("Đã thanh toán")</span>
                </button>
                <button class="filter-tab @(ActiveFilter == "Chưa thanh toán" ? "active" : "")" @onclick='() => SetFilter("Chưa thanh toán")'>
                    Chưa thanh toán <span class="tab-count pending">@CountByStatus("Chưa thanh toán")</span>
                </button>
                <button class="filter-tab @(ActiveFilter == "Đang sử dụng" ? "active" : "")" @onclick='() => SetFilter("Đang sử dụng")'>
                    Đang sử dụng <span class="tab-count active-tab">@CountByStatus("Đang sử dụng")</span>
                </button>
                <button class="filter-tab @(ActiveFilter == "Đã trả phòng" ? "active" : "")" @onclick='() => SetFilter("Đã trả phòng")'>
                    Đã trả phòng <span class="tab-count done">@CountByStatus("Đã trả phòng")</span>
                </button>
            </div>
            <input class="search-input" placeholder="Tìm khách hàng / SĐT..."
                   @bind="SearchTerm" @bind:event="oninput" />
        </div>
    </header>

    @if (IsLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Đang tải lịch đặt phòng...</p>
        </div>
    }
    else if (!FilteredBookings.Any())
    {
        <div class="empty-state">
            <svg viewBox="0 0 24 24" width="64" height="64" fill="currentColor" opacity="0.4">
                <path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-2 .9-2 2v16c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 18H5V9h14v12zM5 7V5h14v2H5z"/>
            </svg>
            <h3>Không có booking nào @(ActiveFilter != "all" ? $"ở trạng thái \"{ActiveFilter}\"" : "")</h3>
            <p>Các booking mới sẽ xuất hiện tại đây.</p>
        </div>
    }
    else
    {
        <div class="bookings-grid">
            @foreach (var booking in FilteredBookings)
            {
                <article class="booking-card @GetStatusClass(booking.Status)">
                    <header class="card-head">
                        <div class="card-id">
                            <span class="id-label">Mã booking</span>
                            <span class="id-value">#BR-@booking.BookingId.ToString("D4")</span>
                        </div>
                        <span class="status-badge">@booking.Status</span>
                    </header>

                    <div class="card-body">
                        <div class="customer-block">
                            <div class="customer-avatar">
                                @(booking.Customer?.Name?.Trim().FirstOrDefault().ToString().ToUpper() ?? "?")
                            </div>
                            <div class="customer-info">
                                <h4>@(booking.Customer?.Name ?? "Khách lẻ")</h4>
                                <div class="contact-line">
                                    <span>📧 @(booking.Customer?.Email ?? "—")</span>
                                </div>
                                <div class="contact-line">
                                    <span>📞 @(booking.Customer?.Phone ?? booking.EmergencyPhone1 ?? "—")</span>
                                </div>
                            </div>
                        </div>

                        <div class="info-grid">
                            <div class="info-item">
                                <span class="info-label">Loại phòng</span>
                                <span class="info-value">@booking.RoomType</span>
                            </div>
                            <div class="info-item">
                                <span class="info-label">Số ngày</span>
                                <span class="info-value">@booking.BoardingDays ngày</span>
                            </div>
                            <div class="info-item">
                                <span class="info-label">Thú cưng</span>
                                <span class="info-value">@ExtractPetCount(booking.PetInfo) con</span>
                            </div>
                            <div class="info-item">
                                <span class="info-label">Đơn giá</span>
                                <span class="info-value">@booking.PricePerDay.ToString("N0")đ/ngày</span>
                            </div>
                        </div>

                        <div class="date-range">
                            <div class="date-block">
                                <span class="date-label">Nhận phòng</span>
                                <span class="date-value">@booking.CheckInDate.ToString("dd/MM/yyyy")</span>
                                <span class="date-relative">@RelativeDate(booking.CheckInDate)</span>
                            </div>
                            <div class="date-arrow">→</div>
                            <div class="date-block">
                                <span class="date-label">Trả phòng</span>
                                <span class="date-value">@booking.CheckOutDate.ToString("dd/MM/yyyy")</span>
                                <span class="date-relative">@RelativeDate(booking.CheckOutDate)</span>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(booking.SpecialNotes))
                        {
                            <div class="notes-block">
                                <span class="notes-label">Ghi chú của khách:</span>
                                <p>@booking.SpecialNotes</p>
                            </div>
                        }

                        <div class="price-row">
                            <span>Tổng tiền</span>
                            <strong class="price-total">@booking.TotalPrice.ToString("N0")đ</strong>
                        </div>
                    </div>

                    <footer class="card-actions">
                        @if (booking.Status == "Chờ xác nhận")
                        {
                            <button class="btn-secondary" @onclick="() => OpenRejectDialog(booking)" disabled="@IsProcessing(booking.BookingId)">
                                ✕ Từ chối
                            </button>
                            <button class="btn-primary" @onclick="() => ConfirmBooking(booking)" disabled="@IsProcessing(booking.BookingId)">
                                @if (IsProcessing(booking.BookingId))
                                {
                                    <span class="dot-spin"></span>
                                    <span>Đang xử lý...</span>
                                }
                                else
                                {
                                    <span>✓ Xác nhận đặt phòng</span>
                                }
                            </button>
                        }
                        else if (booking.Status == "Đã thanh toán")
                        {
                            <button class="btn-info" @onclick="() => CheckInGuest(booking)" disabled="@IsProcessing(booking.BookingId)">
                                🏠 Check-in khách
                            </button>
                        }
                        else if (booking.Status == "Đang sử dụng")
                        {
                            <button class="btn-success" @onclick="() => CheckOutGuest(booking)" disabled="@IsProcessing(booking.BookingId)">
                                🔑 Check-out & hoàn tất
                            </button>
                        }
                        else
                        {
                            <span class="readonly-text">Đã hoàn tất quy trình</span>
                        }
                    </footer>

                    @if (ActionFeedback.TryGetValue(booking.BookingId, out var msg))
                    {
                        <div class="card-feedback @ActionFeedbackClass(booking.BookingId)">@msg</div>
                    }
                </article>
            }
        </div>
    }
</div>

@if (ShowRejectDialog && RejectTarget != null)
{
    <div class="modal-backdrop" @onclick="CloseRejectDialog">
        <div class="modal" @onclick:stopPropagation="true">
            <h3>Từ chối booking</h3>
            <p>Bạn đang từ chối booking <strong>#BR-@RejectTarget.BookingId.ToString("D4")</strong> của <strong>@RejectTarget.Customer?.Name</strong>.</p>
            <label>Lý do từ chối <span class="required">*</span></label>
            <textarea @bind="RejectReason" placeholder="VD: Phòng đã đầy trong khoảng thời gian này..."
                      maxlength="200" rows="3"></textarea>
            <div class="modal-actions">
                <button class="btn-secondary" @onclick="CloseRejectDialog">Hủy</button>
                <button class="btn-primary" @onclick="SubmitReject" disabled="@string.IsNullOrWhiteSpace(RejectReason)">
                    Xác nhận từ chối
                </button>
            </div>
        </div>
    </div>
}

