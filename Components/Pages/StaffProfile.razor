@page "/system/profile"
@layout PetShop_PRN222.Components.Layout.StaffWorkspaceLayout
@rendermode InteractiveServer
@using PetShop.Data
@using Microsoft.EntityFrameworkCore
@using PetShop.Models
@using Microsoft.Extensions.DependencyInjection
@inject IServiceProvider ServiceProvider
@inject NavigationManager Navigation

<PageTitle>Hồ Sơ Của Tôi</PageTitle>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="fox-card p-5 mt-4 text-center shadow-sm border-0">
            @if (staff == null)
            {
                <div class="spinner-border text-primary"></div>
            }
            else
            {
                <div class="position-relative d-inline-block mb-4">
                    <img src="https://ui-avatars.com/api/?name=@(staff.Name)&background=6c5ce7&color=fff&size=150" class="rounded-circle shadow-lg border border-4 border-white" />
                </div>
                <h3 class="fw-bold text-dark">@staff.Name</h3>
                <span class="badge bg-primary px-3 py-2 rounded-pill mb-4 fs-6">Chức vụ: @(staff.Role.ToUpper())</span>

                <div class="text-start mt-4">
                    <div class="mb-3">
                        <label class="fw-bold text-muted mb-2">Họ và Tên</label>
                        <input type="text" class="form-control form-control-lg bg-light border-0 shadow-none" @bind="staff.Name" />
                    </div>
                    <div class="mb-3">
                        <label class="fw-bold text-muted mb-2">Số Điện Thoại</label>
                        <input type="text" class="form-control form-control-lg bg-light border-0 shadow-none" @bind="staff.Phone" />
                    </div>
                    <div class="mb-4">
                        <label class="fw-bold text-muted mb-2">Địa chỉ Email</label>
                        <input type="email" class="form-control form-control-lg bg-light border-0 shadow-none" @bind="staff.Email" />
                    </div>
                    <button class="btn btn-primary btn-lg w-100 rounded-pill fw-bold shadow" style="background: linear-gradient(135deg, #6c5ce7, #a29bfe); border:none;" @onclick="SaveProfile">
                        <i class="fas fa-save me-2"></i> Lưu Cập Nhật
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private Customer? staff;

    protected override async Task OnInitializedAsync()
    {
        using var scope = ServiceProvider.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<ShopPetDatabaseContext>();
        staff = await db.Customers.AsNoTracking().FirstOrDefaultAsync(c => c.CustomerId == 2);
    }

    private async Task SaveProfile()
    {
        if (staff != null)
        {
            // GIẢI PHÁP VÀNG: Dùng SQL Thuần để update, né 100% lỗi Tracking gây đứng hình
            using var scope = ServiceProvider.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<ShopPetDatabaseContext>();

            string sql = "UPDATE Customer SET name = @p0, phone = @p1, email = @p2 WHERE customer_id = 2";
            await db.Database.ExecuteSqlRawAsync(sql, staff.Name, staff.Phone ?? "", staff.Email ?? "");

            // Ép tải lại trang cứng để đổi tên luôn trên Layout góc phải
            Navigation.NavigateTo(Navigation.Uri, forceLoad: true);
        }
    }
}