@code {
    [Parameter, EditorRequired] public string Title { get; set; } = "Danh mục";
    [Parameter] public IReadOnlyList<CategoryOption> Categories { get; set; } = Array.Empty<CategoryOption>();
    [Parameter] public int? SelectedCategoryId { get; set; }
    [Parameter] public EventCallback<int?> OnChange { get; set; }

    public sealed record CategoryOption(int Id, string Name);
}

<aside class="products-sidebar">
    <div class="products-sidebar__header">
        <h3>@Title</h3>
    </div>

    <div class="products-sidebar__list">
        <button type="button"
                class="products-sidebar__item @(SelectedCategoryId is null ? "active" : null)"
                @onclick="() => OnChange.InvokeAsync(null)">
            Tất cả sản phẩm
        </button>

        @foreach (var category in Categories)
        {
            var catId = category.Id;
            <button type="button"
                    class="products-sidebar__item @(SelectedCategoryId == catId ? "active" : null)"
                    @onclick="() => OnChange.InvokeAsync(catId)">
                @category.Name
            </button>
        }
    </div>
</aside>
