@inherits LayoutComponentBase
@using PetShop.Components.Shared
@inject PetShop.Services.CartStateService CartState
@inject IJSRuntime JS

@Body

<ChatWidget />

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">x</a>
</div>

@code {
    private bool _cartInitialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_cartInitialized)
        {
            _cartInitialized = true;
            CartState.AttachRuntime(JS);
            try { await CartState.LoadAsync(); }
            catch (Exception ex) { System.Diagnostics.Debug.WriteLine($"[MainLayout.razor] CartState.LoadAsync threw: {ex.GetType().Name}"); }
        }
    }
}
