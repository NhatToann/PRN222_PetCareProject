@using PetShop.Interfaces
@using PetShop.Models
@inject IChatClient ChatClient
@inject PetShop.Services.UserSessionService UserSession
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<!-- Floating Chat Button -->
<div class="floating-chat-container @(IsOpen ? "active" : "")">
    @if (IsOpen)
    {
        <div class="chat-popup">
            <div class="chat-popup-header">
                <div class="chat-header-info">
                    <div class="chat-avatar">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4zm-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10c-2.29 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10z"/>
                        </svg>
                    </div>
                    <div class="chat-header-text">
                        <h3>Hỗ trợ PetCare</h3>
                        <span class="status-indicator online"></span>
                        <span class="status-text">Đang trực tuyến</span>
                    </div>
                </div>
                <button class="chat-minimize-btn" @onclick="ToggleChat" title="Thu nhỏ">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z"/>
                    </svg>
                </button>
            </div>

            <div class="chat-popup-body">
                @if (!IsAuthenticated)
                {
                    <div class="chat-auth-prompt">
                        <div class="auth-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4zm-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10c-2.29 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10z"/>
                            </svg>
                        </div>
                        <h3>Vui lòng đăng nhập để chat</h3>
                        <p>Bạn cần đăng nhập để có thể nhắn tin hỗ trợ với chúng tôi.</p>
                        <button class="btn-primary" @onclick='() => Navigation.NavigateTo("/login")'>
                            Đăng nhập ngay
                        </button>
                    </div>
                }
                else
                {
                    <div class="chat-messages" id="chatWidgetMessages">
                        @if (IsLoading)
                        {
                            <div class="chat-loading">
                                <div class="spinner"></div>
                                <span>Đang tải tin nhắn...</span>
                            </div>
                        }
                        else if (Messages.Any())
                        {
                            @foreach (var message in Messages)
                            {
                                <div class="message @(message.SenderType == "Customer" ? "message-out" : "message-in")">
                                    <div class="message-bubble">
                                        <p>@message.Message</p>
                                        <span class="message-time">
                                            @FormatTime(message.SentAt)
                                        </span>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="chat-empty">
                                <div class="empty-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M14 1a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H4.414A2 2 0 0 0 3 11.586l-2 2V2a1 1 0 0 1 1-1h12zM2 0a2 2 0 0 0-2 2v12.793a.5.5 0 0 0 .854.353l2.853-2.853A1 1 0 0 1 4.414 12H14a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H2z"/>
                                        <path d="M3 3.5a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5zM3 6a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9A.5.5 0 0 1 3 6zm0 2.5a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5z"/>
                                    </svg>
                                </div>
                                <p>Chưa có tin nhắn nào</p>
                                <span>Gửi tin nhắn cho chúng tôi để được hỗ trợ!</span>
                            </div>
                        }
                    </div>

                    <div class="chat-input-area">
                        <input type="text" 
                               class="chat-input" 
                               placeholder="Nhập tin nhắn..."
                               @bind="NewMessage"
                               @bind:event="oninput"
                               @onkeydown="HandleKeyDown"
                               disabled="@IsSending" />
                        <button class="send-btn @(string.IsNullOrWhiteSpace(NewMessage) ? "disabled" : "")" 
                                @onclick="SendMessage"
                                disabled="@(string.IsNullOrWhiteSpace(NewMessage) || IsSending)">
                            @if (IsSending)
                            {
                                <span class="spinner-small"></span>
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M15.854.146a.5.5 0 0 1 .11.54l-5.819 14.547a.75.75 0 0 1-1.329.124l-3.178-4.995L.643 7.184a.75.75 0 0 1 .124-1.33L15.314.037a.5.5 0 0 1 .54.11ZM6.636 10.07l2.761 4.338L14.13 2.576 6.636 10.07Zm6.787-8.201L1.591 6.602l4.339 2.76 7.494-7.493Z"/>
                                </svg>
                            }
                        </button>
                    </div>
                }
            </div>
        </div>
    }
    
    <button class="floating-chat-btn" @onclick="ToggleChat" title="Chat với chúng tôi">
        @if (IsOpen)
        {
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z"/>
            </svg>
        }
        else
        {
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16">
                <path d="M16 8c0 3.15-1.866 2.585-3.567 2.07C11.42 9.763 10.465 9.473 10 10c-.603.683-.475 1.819-.351 2.92C9.826 14.495 9.996 16 8 16a8 8 0 1 1 8-8c1.996 0 1.826-1.504 1.649-3.08-.124-1.101-.252-2.237.351-2.92.465-.527.813-1.102.813-2.271 0-2.71-1.905-4.545-4.326-5.279C9.345 1.5 9.162 1.5 8 1.5 5.27 1.5 3.188 3.585 3.138 6.289c.046.73.161 1.404.336 2.104C2.655 9.09 2 10.24 2 11.5c0 1.689.856 2.837 1.917 3.515C4.85 15.5 5.72 15.5 6 15.5h5.5c.28 0 .5-.224.5-.5 0-.553-.421-1.079-.5-1.203-.079-.124-.163-.252-.256-.377A.5.5 0 0 0 11 13.5c0-.276.224-.5.5-.5h.5c.28 0 .5.224.5.5 0 .553-.421 1.079-.5 1.203-.079.124-.163.252-.256.377a.5.5 0 0 0 .083.71C11.15 16 11 16.276 11 16.5c0 1.689.856 2.837 1.917 3.515.36.227.69.44.976.63.286.19.617.38.987.53C15.17 21.5 16 21 16 18.5V8z"/>
            </svg>
        }
    </button>
</div>

<style>
    .floating-chat-container {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 9999;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
    }

    .floating-chat-btn {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 50%;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 20px rgba(102, 126, 234, 0.5);
        cursor: pointer;
        transition: all 0.3s ease;
        color: white;
    }

    .floating-chat-btn:hover {
        transform: scale(1.1);
        box-shadow: 0 6px 25px rgba(102, 126, 234, 0.7);
    }

    .chat-popup {
        width: 360px;
        height: 480px;
        background: white;
        border-radius: 16px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
        display: flex;
        flex-direction: column;
        margin-bottom: 16px;
        animation: slideUp 0.3s ease;
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .chat-popup-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 16px;
        border-radius: 16px 16px 0 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .chat-header-info {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .chat-avatar {
        width: 40px;
        height: 40px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .chat-header-text h3 {
        margin: 0;
        font-size: 16px;
        font-weight: 600;
    }

    .status-indicator {
        display: inline-block;
        width: 8px;
        height: 8px;
        background: #4ade80;
        border-radius: 50%;
        margin-left: 4px;
    }

    .status-text {
        font-size: 12px;
        opacity: 0.9;
    }

    .chat-minimize-btn {
        background: rgba(255, 255, 255, 0.2);
        border: none;
        border-radius: 50%;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: white;
        transition: background 0.2s;
    }

    .chat-minimize-btn:hover {
        background: rgba(255, 255, 255, 0.3);
    }

    .chat-popup-body {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .chat-messages {
        flex: 1;
        padding: 16px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .chat-loading, .chat-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        color: #666;
        text-align: center;
        padding: 20px;
    }

    .chat-empty .empty-icon {
        color: #ddd;
        margin-bottom: 12px;
    }

    .chat-empty p {
        margin: 0;
        font-weight: 500;
        color: #333;
    }

    .chat-empty span {
        font-size: 13px;
        color: #999;
        margin-top: 4px;
    }

    .message {
        display: flex;
        max-width: 80%;
    }

    .message-out {
        align-self: flex-end;
    }

    .message-in {
        align-self: flex-start;
    }

    .message-bubble {
        padding: 10px 14px;
        border-radius: 16px;
        position: relative;
    }

    .message-out .message-bubble {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-bottom-right-radius: 4px;
    }

    .message-in .message-bubble {
        background: #f1f1f1;
        color: #333;
        border-bottom-left-radius: 4px;
    }

    .message-bubble p {
        margin: 0;
        font-size: 14px;
        line-height: 1.4;
    }

    .message-time {
        font-size: 10px;
        opacity: 0.7;
        display: block;
        margin-top: 4px;
        text-align: right;
    }

    .chat-input-area {
        padding: 12px 16px;
        border-top: 1px solid #eee;
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .chat-input {
        flex: 1;
        padding: 10px 16px;
        border: 1px solid #ddd;
        border-radius: 24px;
        font-size: 14px;
        outline: none;
        transition: border-color 0.2s;
    }

    .chat-input:focus {
        border-color: #667eea;
    }

    .chat-input:disabled {
        background: #f5f5f5;
    }

    .send-btn {
        width: 44px;
        height: 44px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: white;
        transition: all 0.2s;
        flex-shrink: 0;
    }

    .send-btn:hover:not(.disabled) {
        transform: scale(1.05);
    }

    .send-btn.disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .chat-auth-prompt {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        padding: 24px;
        text-align: center;
    }

    .chat-auth-prompt .auth-icon {
        color: #667eea;
        margin-bottom: 16px;
    }

    .chat-auth-prompt h3 {
        margin: 0 0 8px;
        font-size: 18px;
        color: #333;
    }

    .chat-auth-prompt p {
        margin: 0 0 20px;
        font-size: 14px;
        color: #666;
    }

    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        padding: 12px 24px;
        border-radius: 24px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        transition: transform 0.2s;
    }

    .btn-primary:hover {
        transform: scale(1.05);
    }

    .spinner {
        width: 24px;
        height: 24px;
        border: 3px solid rgba(102, 126, 234, 0.3);
        border-top-color: #667eea;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    .spinner-small {
        width: 16px;
        height: 16px;
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    @@media (max-width: 480px) {
        .chat-popup {
            width: calc(100vw - 48px);
            height: calc(100vh - 120px);
            max-height: 500px;
        }
    }
</style>

@code {
    private bool IsOpen { get; set; } = false;
    private List<ChatMessageDto> Messages { get; set; } = new();
    private string NewMessage { get; set; } = string.Empty;
    private bool IsLoading { get; set; } = false;
    private bool IsSending { get; set; } = false;
    private bool IsAuthenticated { get; set; } = false;
    private int _customerId = 0;
    private CancellationTokenSource? _cts;

    protected override async Task OnInitializedAsync()
    {
        _cts = new CancellationTokenSource();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await CheckAuthentication();
        }
    }

    private async Task CheckAuthentication()
    {
        try
        {
            await UserSession.LoadAsync();
            if (UserSession.IsAuthenticated && UserSession.CurrentUser != null)
            {
                _customerId = UserSession.CurrentUser.UserId;
                IsAuthenticated = true;
                await LoadMessages();
            }
            else
            {
                IsAuthenticated = false;
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error checking auth: {ex.Message}");
            IsAuthenticated = false;
        }
    }

    private async Task ToggleChat()
    {
        IsOpen = !IsOpen;
        
        if (IsOpen)
        {
            await CheckAuthentication();
            if (IsAuthenticated && !Messages.Any())
            {
                await LoadMessages();
            }
        }
        
        StateHasChanged();
    }

    private async Task LoadMessages()
    {
        if (_customerId <= 0) return;
        
        IsLoading = true;
        StateHasChanged();
        
        try
        {
            var result = await ChatClient.GetConversationAsync(_customerId);
            if (result.IsSuccess && result.Data != null)
            {
                Messages = result.Data.Messages.ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading messages: {ex.Message}");
        }
        finally
        {
            IsLoading = false;
            await InvokeAsync(StateHasChanged);
            await ScrollToBottom();
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(NewMessage) || _customerId <= 0 || IsSending)
            return;

        var messageToSend = NewMessage.Trim();
        NewMessage = string.Empty;
        IsSending = true;
        StateHasChanged();

        try
        {
            var result = await ChatClient.SendMessageAsync(_customerId, messageToSend);
            if (result.IsSuccess && result.Data != null)
            {
                Messages.Add(result.Data);
                await InvokeAsync(StateHasChanged);
                await ScrollToBottom();
            }
            else
            {
                Console.WriteLine($"Send error: {result.Error}");
                NewMessage = messageToSend;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
            NewMessage = messageToSend;
        }
        finally
        {
            IsSending = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SendMessage();
        }
    }

    private async Task ScrollToBottom()
    {
        try
        {
            await Task.Delay(100);
            await JSRuntime.InvokeVoidAsync("eval", @"
                var container = document.getElementById('chatWidgetMessages');
                if (container) container.scrollTop = container.scrollHeight;
            ");
        }
        catch { }
    }

    private string FormatTime(DateTime dateTime)
    {
        var localTime = dateTime.Kind == DateTimeKind.Utc 
            ? dateTime.ToLocalTime() 
            : dateTime;
        return localTime.ToString("HH:mm");
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
